<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Pomodorus</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #f0f0f0;
            margin: 0;
            color: #333;
        }
        .container {
            background-color: #fff;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            text-align: center;
        }
        h1 {
            color: #007bff;
            margin-bottom: 20px;
        }
        p#horaAtual {
            font-size: 2em;
            font-weight: bold;
            margin-bottom: 20px;
        }
        #statusAlarme {
            color: #28a745;
            font-weight: bold;
        }
        .input-group {
            margin-top: 20px;
            margin-bottom: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 5px; /* Espaço entre os campos */
        }
        .input-group input {
            width: 60px; /* Largura para os campos de número */
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 5px;
            text-align: center;
            font-size: 1.1em;
            -moz-appearance: textfield; /* Remove setas em Firefox */
        }
        /* Esconde as setas de incremento/decremento em Chrome/Safari/Edge */
        .input-group input::-webkit-outer-spin-button,
        .input-group input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .input-group span {
            font-size: 1.5em;
            font-weight: bold;
        }
        .input-group button {
            padding: 10px 15px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 1em;
            margin-left: 10px;
        }
        .input-group button:hover {
            background-color: #0056b3;
        }
        #mensagemErro {
            color: red;
            margin-top: 10px;
            min-height: 20px; /* Para manter o espaço */
        }
        ul {
            list-style: none;
            padding: 0;
            margin-top: 20px;
        }
        li {
            background-color: #e9ecef;
            margin-bottom: 5px;
            padding: 8px 15px;
            border-radius: 5px;
            display: inline-block;
            margin-right: 5px;
        }
        li button {
            background: none;
            border: none;
            color: #dc3545;
            cursor: pointer;
            margin-left: 10px;
            font-weight: bold;
        }
        li button:hover {
            color: #bd2130;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>My Pomodorus</h1>
        <p>A hora atual é:</p>
        <p id="horaAtual"></p>
        <p id="statusAlarme"></p>

        <h2>Adicionar Novo Alarme:</h2>
        <div class="input-group">
            <input type="number" id="inputHora" min="0" max="23" placeholder="HH" maxlength="2">
            <span>:</span>
            <input type="number" id="inputMinuto" min="0" max="59" placeholder="MM" maxlength="2">
            <button id="btnAddAlarme">Adicionar Alarme</button>
        </div>
        <p id="mensagemErro"></p>

        <h2>Alarmes Configurados:</h2>
        <ul id="listaAlarmes"></ul>

        <audio id="audioAlarme" src="https://github.com/w3teal/awesome-ringtone/raw/refs/heads/main/Vivo/2022%20-%20Indomitable%20will.mp3" preload="auto"></audio>
    </div>

    <script>
        // --- CONFIGURAÇÃO DOS ALARMES ---
        // Pega os alarmes do localStorage ou inicia com uma lista vazia
        let alarmes = JSON.parse(localStorage.getItem('alarmesSalvos')) || [
            [9, 15],  // Exemplo: Alarme às 09:15
            [12, 0]   // Exemplo: Alarme às 12:00
        ];
        // ---------------------------------

        const horaAtualElement = document.getElementById('horaAtual');
        const statusAlarmeElement = document.getElementById('statusAlarme');
        const audioAlarme = document.getElementById('audioAlarme');
        const listaAlarmesElement = document.getElementById('listaAlarmes');
        const inputHora = document.getElementById('inputHora');
        const inputMinuto = document.getElementById('inputMinuto');
        const btnAddAlarme = document.getElementById('btnAddAlarme');
        const mensagemErroElement = document.getElementById('mensagemErro');

        // Adiciona evento de escuta para limitar os inputs a 2 caracteres
        inputHora.addEventListener('input', function() {
            if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);
        });
        inputMinuto.addEventListener('input', function() {
            if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);
        });


        // Função para formatar a hora e exibir
        function atualizarHora() {
            const agora = new Date();
            const horas = String(agora.getHours()).padStart(2, '0');
            const minutos = String(agora.getMinutes()).padStart(2, '0');
            const segundos = String(agora.getSeconds()).padStart(2, '0');
            horaAtualElement.textContent = `${horas}:${minutos}:${segundos}`;

            verificarAlarme(agora.getHours(), agora.getMinutes());
        }

        // Função para verificar se é hora do alarme
        function verificarAlarme(currentHour, currentMinute) {
            const alarmeAtivo = alarmes.find(alarme => {
                const [alarmeHour, alarmeMinute] = alarme;
                return currentHour === alarmeHour && currentMinute === alarmeMinute;
            });

            if (alarmeAtivo) {
                // Para evitar que o alarme toque várias vezes no mesmo minuto
                // Usa audioAlarme.paused para verificar se o áudio não está tocando
                if (audioAlarme.paused) {
                    audioAlarme.play().then(() => {
                        statusAlarmeElement.textContent = `🚨 ALARME TOCANDO! É ${String(alarmeAtivo[0]).padStart(2, '0')}:${String(alarmeAtivo[1]).padStart(2, '0')} 🚨`;
                        console.log('Alarme tocando!');
                    }).catch(error => {
                        console.error('Erro ao tentar tocar o áudio:', error);
                        statusAlarmeElement.textContent = `Erro: Permissão para tocar áudio pode ser necessária.`;
                    });
                }
            } else {
                if (statusAlarmeElement.textContent.includes('ALARME TOCANDO')) {
                    statusAlarmeElement.textContent = ''; // Limpa o status se o alarme já passou
                }
                // Pausa o áudio se não for mais hora do alarme e ele estiver tocando
                if (!audioAlarme.paused) {
                    audioAlarme.pause();
                    audioAlarme.currentTime = 0; // Volta o áudio para o início
                }
            }
        }

        // Função para salvar os alarmes no localStorage
        function salvarAlarmes() {
            localStorage.setItem('alarmesSalvos', JSON.stringify(alarmes));
        }

        // Função para exibir a lista de alarmes configurados na página
        function exibirAlarmesConfigurados() {
            listaAlarmesElement.innerHTML = ''; // Limpa a lista antes de adicionar
            if (alarmes.length === 0) {
                listaAlarmesElement.innerHTML = '<li>Nenhum alarme configurado.</li>';
                return;
            }
            // Ordena os alarmes para melhor visualização
            const alarmesOrdenados = [...alarmes].sort((a, b) => {
                if (a[0] !== b[0]) return a[0] - b[0];
                return a[1] - b[1];
            });

            alarmesOrdenados.forEach((alarme, index) => {
                const li = document.createElement('li');
                li.textContent = `${String(alarme[0]).padStart(2, '0')}:${String(alarme[1]).padStart(2, '0')}`;
                
                // Botão para remover alarme
                const btnRemover = document.createElement('button');
                btnRemover.textContent = 'X';
                btnRemover.title = 'Remover alarme';
                btnRemover.onclick = () => removerAlarme(alarme[0], alarme[1]); // Passa hora e minuto
                li.appendChild(btnRemover);

                listaAlarmesElement.appendChild(li);
            });
        }

        // Função para adicionar um novo alarme
        btnAddAlarme.addEventListener('click', () => {
            const hora = parseInt(inputHora.value, 10);
            const minuto = parseInt(inputMinuto.value, 10);

            mensagemErroElement.textContent = ''; // Limpa mensagens de erro anteriores

            if (isNaN(hora) || isNaN(minuto)) {
                mensagemErroElement.textContent = 'Por favor, insira números válidos para hora e minuto.';
                return;
            }

            if (hora < 0 || hora > 23) {
                mensagemErroElement.textContent = 'A hora deve estar entre 00 e 23.';
                return;
            }

            if (minuto < 0 || minuto > 59) {
                mensagemErroElement.textContent = 'O minuto deve estar entre 00 e 59.';
                return;
            }

            // Verifica se o alarme já existe
            const alarmeExistente = alarmes.some(a => a[0] === hora && a[1] === minuto);
            if (alarmeExistente) {
                mensagemErroElement.textContent = 'Este alarme já foi adicionado.';
                return;
            }

            alarmes.push([hora, minuto]);
            salvarAlarmes(); // Salva no localStorage
            exibirAlarmesConfigurados(); // Atualiza a lista exibida
            inputHora.value = ''; // Limpa os campos
            inputMinuto.value = '';
            inputHora.focus(); // Retorna o foco para o campo de hora
        });

        // Função para remover um alarme
        function removerAlarme(hora, minuto) {
            alarmes = alarmes.filter(alarme => !(alarme[0] === hora && alarme[1] === minuto));
            salvarAlarmes();
            exibirAlarmesConfigurados();
        }

        // Atualiza a hora a cada segundo
        setInterval(atualizarHora, 1000);

        // Exibe os alarmes configurados ao carregar a página
        exibirAlarmesConfigurados();

        // Garante que a hora seja exibida imediatamente ao carregar
        atualizarHora();
    </script>
</body>
</html>
